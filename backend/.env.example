# =============================================================================
# Explainable GNN Imbalance Studio — Backend Environment Variables
# =============================================================================
# This file documents all required environment variables for deployment.
# Copy to .env and fill in your values.

# ── Mode ────────────────────────────────────────────────────────────────────
# Set to "true" for deterministic mock data (no PyTorch/DB/Redis required)
# Set to "false" for real GNN training with full dependencies
MOCK_MODE=true

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Supabase: Use the connection string from Project Settings > Database
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/gnn_studio

# ── Redis Cache ─────────────────────────────────────────────────────────────
# Upstash: Use the REST URL from your Upstash Redis dashboard
# Format: rediss://default:[password]@[endpoint].upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ── Celery (Background Tasks) ───────────────────────────────────────────────
# For Upstash, use the same Redis URL for both broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated). Include your Vercel deployment URL.
# Example: https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Training Defaults ───────────────────────────────────────────────────────
DEFAULT_EPOCHS=200
DEFAULT_LR=0.01
DEFAULT_HIDDEN_DIM=64
DEFAULT_DROPOUT=0.5
DEFAULT_WEIGHT_DECAY=5e-4
RANDOM_SEED=42

# ── Upload Limits ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MAX_UPLOAD_NODES=50000
MAX_UPLOAD_EDGES=500000

# ── Device ──────────────────────────────────────────────────────────────────
# Set to "true" to force CPU even if CUDA is available
FORCE_CPU=false

# =============================================================================
# Cloud Deployment Quick Reference
# =============================================================================
#
# SUPABASE (PostgreSQL):
#   1. Create a new project at supabase.com
#   2. Go to Project Settings > Database > Connection String
#   3. Copy the URI and set as DATABASE_URL
#
# UPSTASH (Redis):
#   1. Create a new Redis database at upstash.com
#   2. Go to Details > REST API
#   3. Copy the UPSTASH_REDIS_REST_URL and set as REDIS_URL
#   4. Use the same URL for CELERY_BROKER_URL and CELERY_RESULT_BACKEND
#
# RENDER / RAILWAY (Backend):
#   1. Create a new Web Service pointing to the backend/ directory
#   2. Set all environment variables above
#   3. Build command: pip install -r requirements.txt
#   4. Start command: uvicorn main:app --host 0.0.0.0 --port $PORT
#
# VERCEL (Frontend):
#   1. Deploy the Next.js app
#   2. Set NEXT_PUBLIC_API_URL to your backend URL (e.g., https://api.yourapp.com)
#
# =============================================================================
