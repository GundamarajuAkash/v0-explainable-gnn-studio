# =============================================================================
# Explainable GNN Studio — Frontend Environment Variables
# =============================================================================
# Copy to .env.local and fill in your values.

# ── Backend API URL ─────────────────────────────────────────────────────────
# Set this to your FastAPI backend URL when deploying.
# Leave empty or commented out to use local mock data (no backend required).
#
# Local development:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (Render/Railway):
#   NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
#
# NEXT_PUBLIC_API_URL=

# =============================================================================
# Deployment Checklist
# =============================================================================
#
# 1. Deploy backend to Render/Railway with DATABASE_URL and REDIS_URL set
# 2. Copy the backend URL (e.g., https://gnn-studio-api.onrender.com)
# 3. In Vercel project settings, add:
#      NEXT_PUBLIC_API_URL = https://gnn-studio-api.onrender.com
# 4. Redeploy frontend
#
# The frontend will automatically use the backend when NEXT_PUBLIC_API_URL is set,
# and fall back to mock data if the backend is unreachable.
#
# =============================================================================
